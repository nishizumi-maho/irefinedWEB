{
  "manifest_version": 3,
  "name": "iRefined Browser",
  "version": "5.2.0",
  "version_name": "v5.2",
  "description": "Loads iRefined on the members-ng iRacing website.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "iRefined Browser",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://members-ng.iracing.com/web/*",
        "https://members-ng.iracing.com/web/racing/*"
      ],
      "css": [
        "extension.css"
      ],
      "js": [
        "main.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://members-ng.iracing.com/web/*",
        "https://members-ng.iracing.com/web/racing/*",
        "https://members.iracing.com/membersite/account/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://members.iracing.com/membersite/account/OrderHistory.do*"
      ],
      "js": [
        "account-main.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
